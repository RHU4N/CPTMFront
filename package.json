{
  "name": "cptmfront",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "dev:api": "dotnet run --project ../CPTMBack/CPTMBack.csproj",
    "dev:full": "npx concurrently -k -n API,WEB -c yellow,cyan \"npm:dev:api\" \"npm:dev\"",
    "preview:full": "npx concurrently -k -n API,WEB -c yellow,green \"npm:dev:api\" \"npm:preview\""
  },
  "dependencies": {
    "axios": "^1.11.0",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.3",
    "vue": "^3.5.34",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^10.0.3",
    "playwright": "^1.60.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.2.0"
  }
}
